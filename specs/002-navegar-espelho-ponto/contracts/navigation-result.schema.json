{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homologacao-ponto.local/contracts/navigation-result.schema.json",
  "title": "NavigationResult",
  "type": "object",
  "required": [
    "run_id",
    "completed_at",
    "username_ref",
    "status",
    "success",
    "final_step",
    "steps"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "username_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial", "blocked"]
    },
    "success": {
      "type": "boolean"
    },
    "final_step": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": ["string", "null"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/NavigationStep"
      }
    },
    "output_path": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "completed" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "success": { "const": true },
          "final_step": { "const": "Espelho do Ponto" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "enum": ["failed", "partial", "blocked"] }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "success": { "const": false },
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["message"]
      }
    }
  ],
  "$defs": {
    "NavigationStep": {
      "type": "object",
      "required": ["label", "position", "status"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "enum": [
            "Chefia de Unidade",
            "Homologacao de Ponto Eletronico",
            "Relatorio",
            "Espelho do Ponto"
          ]
        },
        "position": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "found",
            "hovered",
            "clicked",
            "missing",
            "timed_out",
            "blocked",
            "expired",
            "destination_mismatch"
          ]
        },
        "message": {
          "type": ["string", "null"]
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}
