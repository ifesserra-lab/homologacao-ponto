---
import type { RegistroDia } from "../types/dashboard";
import type { OcorrenciaCategoria } from "../lib/aggregation";
import { formatMin, parseHHMM, isAbsentWorkDay, JORNADA_MIN, classifyOcorrencia, cleanOcorrenciaTexto } from "../lib/aggregation";

interface Props {
  registros: RegistroDia[];
}

const { registros } = Astro.props;

// OcorrenciaCategoria is imported from aggregation

interface BadgeInfo {
  symbol: string;
  label: string;
  tooltip: string;
  cls: string;
}

const BADGE: Record<NonNullable<OcorrenciaCategoria>, BadgeInfo> = {
  pit: {
    symbol: "✎",
    label: "PIT",
    tooltip: "Plano Individual de Trabalho — horas de docente registradas sem batida de relógio",
    cls: "badge-pit",
  },
  abono: {
    symbol: "◎",
    label: "Abono",
    tooltip: "Horas abonadas ou regime especial autorizado pela chefia",
    cls: "badge-abono",
  },
  afastamento: {
    symbol: "⊘",
    label: "Afas.",
    tooltip: "Afastamento legal (licença saúde, paternidade, estudo exterior etc.)",
    cls: "badge-afastamento",
  },
  recesso: {
    symbol: "◷",
    label: "Recesso",
    tooltip: "Recesso institucional ou feriado a compensar",
    cls: "badge-recesso",
  },
  sistema: {
    symbol: "⚠",
    label: "Sist.",
    tooltip: "SIGRH indisponível no dia — marcação não pôde ser registrada",
    cls: "badge-sistema",
  },
};

function categoriaOcorrencia(r: RegistroDia): OcorrenciaCategoria | null {
  return classifyOcorrencia(r.ocorrencias ?? []);
}

/** Remove date ranges and verbosity from occurrence text for compact display. */
function cleanOcorrencia(text: string): string {
  return cleanOcorrenciaTexto(text);
}

/** Full tooltip: all occurrences raw, for detail on hover. */
function ocorrenciasTooltip(r: RegistroDia): string {
  return (r.ocorrencias ?? []).join("\n");
}

function isIncompleta(r: RegistroDia): boolean {
  if (categoriaOcorrencia(r) !== null) return false;
  const d = parseHHMM(r.debito);
  if (d !== null && d > 0) return true;
  return isAbsentWorkDay(r);
}

function displayDate(val: string | null | undefined): string {
  if (!val) return "—";
  const parts = val.split("-");
  if (parts.length !== 3) return val;
  return `${parts[2]}/${parts[1]}/${parts[0]}`;
}

function displayHHMM(val: string | null | undefined): string {
  if (val === null || val === undefined) return "—";
  const m = parseHHMM(val);
  return m !== null ? formatMin(m) : val;
}

function displayDebito(r: RegistroDia): { value: string; implicit: boolean } {
  if (r.debito !== null && r.debito !== undefined) {
    const m = parseHHMM(r.debito);
    if (m !== null && m > 0) return { value: `-${formatMin(m)}`, implicit: false };
    if (m === 0) return { value: "—", implicit: false };
    return { value: r.debito, implicit: false };
  }
  if (isAbsentWorkDay(r)) {
    return { value: `-${formatMin(JORNADA_MIN)}`, implicit: true };
  }
  return { value: "—", implicit: false };
}

const DIA_SEMANA: Record<number, string> = {
  0: "Domingo", 1: "Segunda", 2: "Terça", 3: "Quarta", 4: "Quinta", 5: "Sexta", 6: "Sábado",
};

function displayDiaSemana(r: RegistroDia): string {
  if (r.dia_semana) return r.dia_semana;
  if (!r.data) return "—";
  const dow = new Date(r.data + "T12:00:00Z").getUTCDay();
  return DIA_SEMANA[dow] ?? "—";
}

function rowClass(r: RegistroDia): string {
  const cat = categoriaOcorrencia(r);
  if (cat) return `row-ocorr row-${cat}`;
  if (isIncompleta(r)) return "row-incomplete";
  return "";
}
---

<details class="col-legend">
  <summary>Legenda das colunas</summary>
  <dl class="legend-grid">
    <div><dt>HR</dt><dd>Hora Regular — horas normais trabalhadas</dd></div>
    <div><dt>HC</dt><dd>Hora Compensatória — horas de compensação de saldo</dd></div>
    <div><dt>HE</dt><dd>Hora Extra — horas além da jornada normal</dd></div>
    <div><dt>HA</dt><dd>Hora de Abono/Afastamento — horas abonadas ou afastamento</dd></div>
    <div><dt>HH</dt><dd>Horas Habituais — variação diária (crédito extra ou débito)</dd></div>
    <div><dt>Crédito</dt><dd>Total de horas creditadas no dia pelo SIGRH</dd></div>
    <div><dt>Débito</dt><dd>Horas em déficit; <em>itálico</em> = calculado (dia útil sem registro)</dd></div>
    <div><dt>Saldo</dt><dd>Saldo acumulado no mês até este dia</dd></div>
    <div><dt>C.Acum.</dt><dd>Crédito Acumulado — saldo corrente do período</dd></div>
    <div><dt>DNC</dt><dd>Diferença Não Compensada — saldo final após apuração do dia</dd></div>
    <div><dt>Situação</dt><dd>Status do registro no ponto eletrônico</dd></div>
    <div><dt><span class="badge-pit">✎ REGISTRO DO PIT - DOCENTE</span></dt><dd>Plano Individual de Trabalho — docente sem batida de relógio</dd></div>
    <div><dt><span class="badge-abono">◎ ABONO DE HORAS</span></dt><dd>Horas abonadas ou regime especial autorizado</dd></div>
    <div><dt><span class="badge-afastamento">⊘ LICENÇA PARA TRATAMENTO DE SAÚDE</span></dt><dd>Afastamentos legais — texto exato da ocorrência exibido</dd></div>
    <div><dt><span class="badge-recesso">◷ Recesso 2025</span></dt><dd>Recesso institucional ou feriado a compensar</dd></div>
    <div><dt><span class="badge-sistema">⚠ INDISPONIBILIDADE DO SISTEMA</span></dt><dd>SIGRH indisponível — marcação não registrada</dd></div>
  </dl>
</details>

<div class="table-wrap">
  <table class="day-table">
    <thead>
      <tr>
        <th title="Data do registro">Data</th>
        <th title="Dia da semana">Dia</th>
        <th title="Registros de ponto (batidas de entrada e saída)">Marcações</th>
        <th class="num" title="Hora Regular — horas normais trabalhadas no dia">HR</th>
        <th class="num" title="Hora Compensatória — horas usadas para compensação de saldo">HC</th>
        <th class="num" title="Hora Extra — horas trabalhadas além da jornada">HE</th>
        <th class="num" title="Hora de Abono/Afastamento — horas abonadas ou de afastamento">HA</th>
        <th class="num" title="Horas Habituais — variação do dia (crédito extra ou débito)">HH</th>
        <th class="num" title="Crédito — total de horas creditadas no dia">Crédito</th>
        <th class="num" title="Débito — horas em déficit; itálico = calculado (dia sem registro)">Débito</th>
        <th class="num" title="Saldo no mês — saldo acumulado até este dia">Saldo</th>
        <th class="num" title="Crédito Acumulado — saldo corrente acumulado no período">C.Acum.</th>
        <th class="num" title="Diferença Não Compensada — saldo final do dia após apuração">DNC</th>
        <th title="Situação do registro no ponto eletrônico">Situação</th>
      </tr>
    </thead>
    <tbody>
      {registros.map((r) => {
        const cat = categoriaOcorrencia(r);
        const badge = cat ? BADGE[cat] : null;
        const deb = displayDebito(r);
        const incompleta = isIncompleta(r);
        return (
          <tr data-data={r.data} class={rowClass(r)}>
            <td class="date">{displayDate(r.data)}</td>
            <td class="muted sm">{displayDiaSemana(r)}</td>
            <td class="marcacoes">
              {badge
                ? (
                  <span class={badge.cls} title={ocorrenciasTooltip(r)}>
                    {badge.symbol}&nbsp;{cleanOcorrencia((r.ocorrencias ?? [])[0] ?? "")}
                  </span>
                )
                : r.marcacoes.length > 0
                  ? r.marcacoes.join("  ")
                  : <span class="muted">—</span>
              }
            </td>
            <td class="num mono">{displayHHMM(r.hr)}</td>
            <td class="num mono">{displayHHMM(r.hc)}</td>
            <td class="num mono">{displayHHMM(r.he)}</td>
            <td class="num mono">{displayHHMM(r.ha)}</td>
            <td class="num mono">{displayHHMM(r.hh)}</td>
            <td class="num mono">{displayHHMM(r.credito)}</td>
            <td class={`num mono${incompleta ? " val-warn" : ""}${deb.implicit ? " val-implicit" : ""}`}>
              {deb.value}
            </td>
            <td class="num mono muted">{displayHHMM(r.saldo_no_mes)}</td>
            <td class="num mono muted">{displayHHMM(r.credito_acumulado)}</td>
            <td class="num mono">{r.dnc !== null && r.dnc !== undefined ? r.dnc : "—"}</td>
            <td class="muted sm">{r.situacao ?? "—"}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<style>
  .day-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .day-table th {
    text-align: left; padding: 9px 12px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
    font-size: 10.5px; font-weight: 500;
    color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.07em;
    white-space: nowrap;
  }
  .day-table td { padding: 9px 12px; border-bottom: 1px solid var(--table-border-soft); white-space: nowrap; }
  .day-table tbody tr:last-child td { border-bottom: none; }
  .day-table tbody tr:hover td { background: var(--table-row-hover); }

  /* ── Row states ─────────────────────────────────────────────────── */
  .row-incomplete td { background: var(--row-incomplete); }
  .row-incomplete:hover td { background: var(--row-incomplete-hover); }

  .row-pit        td { background: color-mix(in srgb, #3b82f6 5%, transparent); }
  .row-abono      td { background: color-mix(in srgb, #22c55e 6%, transparent); }
  .row-afastamento td { background: color-mix(in srgb, #f59e0b 7%, transparent); }
  .row-recesso    td { background: color-mix(in srgb, #a78bfa 7%, transparent); }
  .row-sistema    td { background: color-mix(in srgb, #94a3b8 6%, transparent); }

  .row-pit:hover        td { background: color-mix(in srgb, #3b82f6 10%, transparent); }
  .row-abono:hover      td { background: color-mix(in srgb, #22c55e 12%, transparent); }
  .row-afastamento:hover td { background: color-mix(in srgb, #f59e0b 13%, transparent); }
  .row-recesso:hover    td { background: color-mix(in srgb, #a78bfa 13%, transparent); }
  .row-sistema:hover    td { background: color-mix(in srgb, #94a3b8 12%, transparent); }

  /* ── Badges ─────────────────────────────────────────────────────── */
  .badge-pit,
  .badge-abono,
  .badge-afastamento,
  .badge-recesso,
  .badge-sistema {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: default;
    white-space: normal;
    max-width: 260px;
    line-height: 1.4;
  }

  .badge-pit {
    background: color-mix(in srgb, #3b82f6 12%, transparent);
    color: #3b82f6;
    border: 1px solid color-mix(in srgb, #3b82f6 30%, transparent);
  }
  .badge-abono {
    background: color-mix(in srgb, #22c55e 12%, transparent);
    color: #16a34a;
    border: 1px solid color-mix(in srgb, #22c55e 35%, transparent);
  }
  .badge-afastamento {
    background: color-mix(in srgb, #f59e0b 12%, transparent);
    color: #b45309;
    border: 1px solid color-mix(in srgb, #f59e0b 35%, transparent);
  }
  .badge-recesso {
    background: color-mix(in srgb, #a78bfa 12%, transparent);
    color: #7c3aed;
    border: 1px solid color-mix(in srgb, #a78bfa 35%, transparent);
  }
  .badge-sistema {
    background: color-mix(in srgb, #94a3b8 12%, transparent);
    color: #64748b;
    border: 1px solid color-mix(in srgb, #94a3b8 35%, transparent);
  }

  /* ── Misc ───────────────────────────────────────────────────────── */
  .num     { text-align: right; }
  .mono    { font-family: var(--mono); font-size: 11.5px; font-variant-numeric: tabular-nums; }
  .muted   { color: var(--muted); }
  .sm      { font-size: 11.5px; }
  .date    { font-weight: 500; font-variant-numeric: tabular-nums; }
  .marcacoes { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.01em; white-space: nowrap; }
  .marcacoes:has(.badge-pit, .badge-abono, .badge-afastamento, .badge-recesso, .badge-sistema) { white-space: normal; min-width: 180px; max-width: 280px; }
  .val-warn { color: var(--red); font-weight: 600; }
  .val-implicit { font-style: italic; opacity: 0.75; }

  /* ── Legend ─────────────────────────────────────────────────────── */
  .col-legend { margin-top: 12px; }
  .col-legend summary {
    font-size: 11.5px; color: var(--muted); cursor: pointer;
    user-select: none; padding: 4px 0; list-style: none;
  }
  .col-legend summary::before { content: "▸ "; font-size: 10px; }
  .col-legend[open] summary::before { content: "▾ "; }
  .legend-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 4px 20px; margin-top: 8px; padding: 12px 14px;
    background: var(--surface-2); border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .legend-grid div { display: flex; gap: 8px; align-items: baseline; }
  .legend-grid dt { font-family: var(--mono); font-size: 11px; font-weight: 600; color: var(--text); min-width: 52px; flex-shrink: 0; }
  .legend-grid dd { font-size: 11.5px; color: var(--muted); margin: 0; }
</style>
