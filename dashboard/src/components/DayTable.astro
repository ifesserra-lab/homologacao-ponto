---
import type { RegistroDia } from "../types/dashboard";
import { formatMin, parseHHMM, isAbsentWorkDay, JORNADA_MIN } from "../lib/aggregation";

interface Props {
  registros: RegistroDia[];
}

const { registros } = Astro.props;

function display(val: string | null | undefined): string {
  return val ?? "—";
}

function displayDate(val: string | null | undefined): string {
  if (!val) return "—";
  // val is ISO "yyyy-mm-dd" → "dd/mm/yyyy"
  const parts = val.split("-");
  if (parts.length !== 3) return val;
  return `${parts[2]}/${parts[1]}/${parts[0]}`;
}

function displayHHMM(val: string | null | undefined): string {
  if (val === null || val === undefined) return "—";
  const m = parseHHMM(val);
  return m !== null ? formatMin(m) : val;
}

function isIncompleta(r: RegistroDia): boolean {
  const d = parseHHMM(r.debito);
  if (d !== null && d > 0) return true;
  return isAbsentWorkDay(r);
}

function displayDebito(r: RegistroDia): { value: string; implicit: boolean } {
  if (r.debito !== null && r.debito !== undefined) {
    const m = parseHHMM(r.debito);
    if (m !== null && m > 0) return { value: `-${formatMin(m)}`, implicit: false };
    if (m === 0) return { value: "—", implicit: false };
    return { value: r.debito, implicit: false };
  }
  if (isAbsentWorkDay(r)) {
    return { value: `-${formatMin(JORNADA_MIN)}`, implicit: true };
  }
  return { value: "—", implicit: false };
}

const DIA_SEMANA: Record<number, string> = {
  0: "Domingo", 1: "Segunda", 2: "Terça", 3: "Quarta", 4: "Quinta", 5: "Sexta", 6: "Sábado"
};

function displayDiaSemana(r: RegistroDia): string {
  if (r.dia_semana) return r.dia_semana;
  if (!r.data) return "—";
  const dow = new Date(r.data + "T12:00:00Z").getUTCDay();
  return DIA_SEMANA[dow] ?? "—";
}
---

<details class="col-legend">
  <summary>Legenda das colunas</summary>
  <dl class="legend-grid">
    <div><dt>HR</dt><dd>Hora Regular — horas normais trabalhadas</dd></div>
    <div><dt>HC</dt><dd>Hora Compensatória — horas de compensação de saldo</dd></div>
    <div><dt>HE</dt><dd>Hora Extra — horas além da jornada normal</dd></div>
    <div><dt>HA</dt><dd>Hora de Abono/Afastamento — horas abonadas ou afastamento</dd></div>
    <div><dt>HH</dt><dd>Horas Habituais — variação diária (crédito extra ou débito)</dd></div>
    <div><dt>Crédito</dt><dd>Total de horas creditadas no dia pelo SIGRH</dd></div>
    <div><dt>Débito</dt><dd>Horas em déficit; <em>itálico</em> = calculado (dia útil sem registro)</dd></div>
    <div><dt>Saldo</dt><dd>Saldo acumulado no mês até este dia</dd></div>
    <div><dt>C.Acum.</dt><dd>Crédito Acumulado — saldo corrente do período</dd></div>
    <div><dt>DNC</dt><dd>Diferença Não Compensada — saldo final após apuração do dia</dd></div>
    <div><dt>Situação</dt><dd>Status do registro no ponto eletrônico</dd></div>
  </dl>
</details>

<div class="table-wrap">
  <table class="day-table">
    <thead>
      <tr>
        <th title="Data do registro">Data</th>
        <th title="Dia da semana">Dia</th>
        <th title="Registros de ponto (batidas de entrada e saída)">Marcações</th>
        <th class="num" title="Hora Regular — horas normais trabalhadas no dia">HR</th>
        <th class="num" title="Hora Compensatória — horas usadas para compensação de saldo">HC</th>
        <th class="num" title="Hora Extra — horas trabalhadas além da jornada">HE</th>
        <th class="num" title="Hora de Abono/Afastamento — horas abonadas ou de afastamento">HA</th>
        <th class="num" title="Horas Habituais — variação do dia (crédito extra ou débito)">HH</th>
        <th class="num" title="Crédito — total de horas creditadas no dia">Crédito</th>
        <th class="num" title="Débito — horas em déficit; itálico = calculado (dia sem registro)">Débito</th>
        <th class="num" title="Saldo no mês — saldo acumulado até este dia">Saldo</th>
        <th class="num" title="Crédito Acumulado — saldo corrente acumulado no período">C.Acum.</th>
        <th class="num" title="Diferença Não Compensada — saldo final do dia após apuração">DNC</th>
        <th title="Situação do registro no ponto eletrônico">Situação</th>
      </tr>
    </thead>
    <tbody>
      {registros.map((r) => (
        <tr data-data={r.data} class={isIncompleta(r) ? "row-incomplete" : ""}>
          <td class="date">{displayDate(r.data)}</td>
          <td class="muted sm">{displayDiaSemana(r)}</td>
          <td class="marcacoes">{r.marcacoes.length > 0 ? r.marcacoes.join("  ") : <span class="muted">—</span>}</td>
          <td class="num mono">{displayHHMM(r.hr)}</td>
          <td class="num mono">{displayHHMM(r.hc)}</td>
          <td class="num mono">{displayHHMM(r.he)}</td>
          <td class="num mono">{displayHHMM(r.ha)}</td>
          <td class="num mono">{displayHHMM(r.hh)}</td>
          <td class="num mono">{displayHHMM(r.credito)}</td>
          {(() => { const deb = displayDebito(r); return <td class={`num mono ${isIncompleta(r) ? "val-warn" : ""}${deb.implicit ? " val-implicit" : ""}`}>{deb.value}</td>; })()}
          <td class="num mono muted">{displayHHMM(r.saldo_no_mes)}</td>
          <td class="num mono muted">{displayHHMM(r.credito_acumulado)}</td>
          <td class="num mono">{r.dnc !== null && r.dnc !== undefined ? r.dnc : "—"}</td>
          <td class="muted sm">{display(r.situacao)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .day-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .day-table th {
    text-align: left; padding: 9px 12px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
    font-size: 10.5px; font-weight: 500;
    color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.07em;
    white-space: nowrap;
  }
  .day-table td { padding: 9px 12px; border-bottom: 1px solid #f0f0f2; white-space: nowrap; }
  .day-table tbody tr:last-child td { border-bottom: none; }
  .day-table tbody tr:hover td { background: #f9f9fb; }

  .row-incomplete td { background: #fff5f2; }
  .row-incomplete:hover td { background: #ffece8; }

  .num     { text-align: right; }
  .mono    { font-family: var(--mono); font-size: 11.5px; font-variant-numeric: tabular-nums; }
  .muted   { color: var(--muted); }
  .sm      { font-size: 11.5px; }
  .date    { font-weight: 500; font-variant-numeric: tabular-nums; }
  .marcacoes { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.01em; }
  .val-warn { color: var(--red); font-weight: 600; }
  .val-implicit { font-style: italic; opacity: 0.75; }

  .col-legend { margin-top: 12px; }
  .col-legend summary {
    font-size: 11.5px; color: var(--muted); cursor: pointer;
    user-select: none; padding: 4px 0; list-style: none;
  }
  .col-legend summary::before { content: "▸ "; font-size: 10px; }
  .col-legend[open] summary::before { content: "▾ "; }
  .legend-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 4px 20px; margin-top: 8px; padding: 12px 14px;
    background: var(--surface-2); border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .legend-grid div { display: flex; gap: 8px; align-items: baseline; }
  .legend-grid dt { font-family: var(--mono); font-size: 11px; font-weight: 600; color: var(--text); min-width: 52px; flex-shrink: 0; }
  .legend-grid dd { font-size: 11.5px; color: var(--muted); margin: 0; }
</style>
