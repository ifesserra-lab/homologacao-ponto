---
import { listServers, loadAllAfastamentos } from "../lib/espelhoRepository";
import { formatMin, pctCarga, allPeriodos } from "../lib/aggregation";
import ThemeToggle from "../components/ThemeToggle.astro";

const dataDir = import.meta.env.DATA_DIR as string | undefined;
const servidores = listServers(dataDir);

// Gather all unique sorted periods
const allMeses = allPeriodos(servidores.map((s) => s.meses));

// Per-server latest completed month summary
const serverLatest = servidores.map((s) => {
  const completed = s.meses.filter((m) => m.status === "completed");
  const latest = completed[completed.length - 1] ?? null;
  return { servidor: s, latest };
});

// Sorted by saldo (ascending: most negative first = most at risk)
const ranked = [...serverLatest].sort((a, b) => {
  const ba = a.latest?.balanceMin ?? Infinity;
  const bb = b.latest?.balanceMin ?? Infinity;
  return ba - bb;
});

// Build heatmap: server → period → month data
const heatmap = servidores.map((s) => {
  const byPeriod = new Map(s.meses.map((m) => [m.periodoReferencia, m]));
  return { servidor: s, byPeriod };
});

// Alerts
const ALERT_THRESH_MIN = -480; // -8h
const WARN_PCT = 60;

const alerts: { serverName: string; slug: string; period: string | null; msg: string; level: "alert" | "warn" }[] = [];
for (const { servidor, latest } of serverLatest) {
  if (!latest) continue;
  if (latest.balanceMin !== null && latest.balanceMin < ALERT_THRESH_MIN) {
    alerts.push({
      serverName: servidor.nome,
      slug: servidor.slug,
      period: latest.periodoReferencia,
      msg: `Saldo ${formatMin(latest.balanceMin)} — abaixo de −08:00`,
      level: "alert",
    });
  }
  const pct = pctCarga(latest.somaCreditoMin, latest.cargaEsperadaMin);
  if (pct !== null && pct < WARN_PCT) {
    alerts.push({
      serverName: servidor.nome,
      slug: servidor.slug,
      period: latest.periodoReferencia,
      msg: `Apenas ${pct}% da carga horária cumprida em ${latest.periodoReferencia}`,
      level: "warn",
    });
  }
}

// ── Novos indicadores ──────────────────────────────────────────────────

const afastamentos = loadAllAfastamentos(dataDir);

// Indicador 1: taxa de presença real por servidor (último mês completo)
const presencaReal = serverLatest.map(({ servidor, latest }) => {
  if (!latest || latest.status !== "completed") return { servidor, pct: null, diasMarcacoes: 0, diasEsperados: 0, periodo: null as string | null };
  const diasEsperados = latest.cargaEsperadaMin > 0 ? Math.round(latest.cargaEsperadaMin / 480) : 0;
  const pct = diasEsperados > 0 ? Math.round((latest.daysWithMarcacoes / diasEsperados) * 100) : null;
  return { servidor, pct, diasMarcacoes: latest.daysWithMarcacoes, diasEsperados, periodo: latest.periodoReferencia };
}).sort((a, b) => (b.pct ?? -1) - (a.pct ?? -1));

// Indicador 2: breakdown ocorrências por servidor (soma todos os meses)
const ocorrBreakdown = servidores.map((s) => {
  const totals = { pit: 0, abono: 0, afastamento: 0, recesso: 0, sistema: 0 };
  for (const m of s.meses) {
    if (!m.ocorrenciaDias) continue;
    totals.pit += m.ocorrenciaDias.pit;
    totals.abono += m.ocorrenciaDias.abono;
    totals.afastamento += m.ocorrenciaDias.afastamento;
    totals.recesso += m.ocorrenciaDias.recesso;
    totals.sistema += m.ocorrenciaDias.sistema;
  }
  const total = totals.pit + totals.abono + totals.afastamento + totals.recesso + totals.sistema;
  return { servidor: s, totals, total };
}).filter(x => x.total > 0).sort((a, b) => b.total - a.total);

// Indicador 3: ranking por abonos
const rankingAbono = [...ocorrBreakdown]
  .filter(x => x.totals.abono > 0)
  .sort((a, b) => b.totals.abono - a.totals.abono);

// Indicador 4: dias perdidos por sistema
const rankingSistema = [...ocorrBreakdown]
  .filter(x => x.totals.sistema > 0)
  .sort((a, b) => b.totals.sistema - a.totals.sistema);

// Indicador 5: PIT vs real (docentes)
const pitVsReal = serverLatest
  .filter(({ latest }) => latest && latest.ocorrenciaDias && latest.ocorrenciaDias.pit > 0)
  .map(({ servidor, latest }) => ({
    servidor,
    pitPct: latest!.pitJustificadoPct,
    diasPit: latest!.ocorrenciaDias.pit,
    diasMarcacoes: latest!.daysWithMarcacoes,
    periodo: latest!.periodoReferencia,
  }))
  .sort((a, b) => (b.pitPct ?? 0) - (a.pitPct ?? 0));

// Indicador 6: afastamentos — filtrar categoria=afastamento
const apenasAfastamentos = afastamentos.filter(a => a.categoria === "afastamento");

// Resumo global
const globalTotais = {
  servidores: servidores.length,
  periodos: allMeses.length,
  horasHomologadas: servidores.reduce((s, srv) => s + srv.meses.reduce((ms, m) => ms + m.somaCreditoMin, 0), 0),
  diasPit: ocorrBreakdown.reduce((s, x) => s + x.totals.pit, 0),
  diasAbono: ocorrBreakdown.reduce((s, x) => s + x.totals.abono, 0),
  totalAfastamentos: apenasAfastamentos.length,
  servidoresComSaldoNeg: serverLatest.filter(({ latest }) => latest && latest.balanceMin !== null && latest.balanceMin < 0).length,
};

function saldoClass(min: number | null): string {
  if (min === null) return "hm-empty";
  if (min === 0) return "hm-zero";
  if (min > 0) return "hm-pos";
  if (min >= -240) return "hm-neg-mild"; // up to -4h
  return "hm-neg-severe";
}

function chipClass(min: number | null): string {
  if (min === null || min === 0) return "zero";
  if (min > 0) return "pos";
  if (min >= -240) return "neg-mild";
  return "neg-severe";
}

function rankBadgeClass(i: number): string {
  if (i === 0) return "gold";
  if (i === 1) return "silver";
  if (i === 2) return "bronze";
  return "";
}

function formatDate(iso: string): string {
  if (!iso) return "—";
  const parts = iso.split("-");
  if (parts.length !== 3) return iso;
  return `${parts[2]}/${parts[1]}/${parts[0]}`;
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Indicadores — Espelhos de Ponto</title>
    <script is:inline>
      const theme = localStorage.getItem("dashboard_theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = theme === "dark" || theme === "light" ? theme : prefersDark ? "dark" : "light";
    </script>
    <link rel="stylesheet" href="/styles/global.css" />
    <script src="/scripts/theme.js" defer></script>
  </head>
  <body>
    <div class="page-wide">
      <div class="nav-row">
        <a class="back" href="/">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Servidores
        </a>
        <div class="nav-actions">
          <ThemeToggle />
          <button class="logout-btn" data-action="logout" type="button">Sair</button>
        </div>
      </div>

      <header class="page-header">
        <h1 class="page-title">Indicadores</h1>
        <p class="page-meta">Comparativo entre {servidores.length} servidores · {allMeses.length} períodos</p>
      </header>

      {/* ── Resumo Global ── */}
      <div class="section">
        <div class="section-title">Resumo Global</div>
        <div class="kpi-grid">
          <div class="kpi-card"><span class="kpi-val">{globalTotais.servidores}</span><span class="kpi-label">Servidores</span></div>
          <div class="kpi-card"><span class="kpi-val">{globalTotais.periodos}</span><span class="kpi-label">Períodos</span></div>
          <div class="kpi-card"><span class="kpi-val">{formatMin(globalTotais.horasHomologadas)}</span><span class="kpi-label">Total Horas Homologadas</span></div>
          <div class="kpi-card kpi-blue"><span class="kpi-val">{globalTotais.diasPit}</span><span class="kpi-label">Dias PIT</span></div>
          <div class="kpi-card kpi-green"><span class="kpi-val">{globalTotais.diasAbono}</span><span class="kpi-label">Dias de Abono</span></div>
          <div class="kpi-card kpi-amber"><span class="kpi-val">{globalTotais.totalAfastamentos}</span><span class="kpi-label">Afastamentos</span></div>
          <div class="kpi-card kpi-red"><span class="kpi-val">{globalTotais.servidoresComSaldoNeg}</span><span class="kpi-label">Com Saldo Negativo</span></div>
        </div>
      </div>

      {/* ── Alertas ── */}
      {alerts.length > 0 && (
        <div class="section">
          <div class="section-title">Alertas</div>
          <div class="alert-list">
            {alerts.map((a) => (
              <div class={`alert-item ${a.level === "warn" ? "warn" : ""}`}>
                <span class="alert-icon">{a.level === "alert" ? "⚠️" : "🔔"}</span>
                <div class="alert-body">
                  <strong><a href={`/servidor/${a.slug}`} style="color:inherit">{a.serverName}</a></strong>
                  {a.msg}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ── Ranking ── */}
      <div class="section">
        <div class="section-title">Ranking por saldo (período mais recente)</div>
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <table class="rank-table">
            <thead>
              <tr>
                <th style="width:40px">#</th>
                <th>Servidor</th>
                <th>Período</th>
                <th>Horas Homologadas</th>
                <th>% Carga</th>
                <th>Saldo do Mês</th>
              </tr>
            </thead>
            <tbody>
              {ranked.map(({ servidor, latest }, i) => {
                const pct = latest ? pctCarga(latest.somaCreditoMin, latest.cargaEsperadaMin) : null;
                const balMin = latest?.balanceMin ?? null;
                return (
                  <tr>
                    <td>
                      <span class={`rank-badge ${rankBadgeClass(i)}`}>{i + 1}</span>
                    </td>
                    <td>
                      <a href={`/servidor/${servidor.slug}`}>{servidor.nome}</a>
                    </td>
                    <td style="color: var(--muted); font-size: 12px;">{latest?.periodoReferencia ?? "—"}</td>
                    <td class="mono">{latest ? formatMin(latest.somaCreditoMin) : "—"}</td>
                    <td>
                      {pct !== null ? (
                        <div class="progress-bar-wrap">
                          <div class="progress-bar-track">
                            <div
                              class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                              style={`width: ${pct}%`}
                            ></div>
                          </div>
                          <span class="progress-pct">{pct}%</span>
                        </div>
                      ) : "—"}
                    </td>
                    <td>
                      <span class={`saldo-chip ${chipClass(balMin)}`}>
                        {balMin !== null ? (balMin >= 0 ? "+" : "") + formatMin(balMin) : "—"}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      {/* ── Heatmap ── */}
      {allMeses.length > 0 && (
        <div class="section">
          <div class="section-title">Saldo por servidor × mês</div>
          <div class="heatmap-wrap" style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm);">
            <table class="heatmap-table">
              <thead>
                <tr>
                  <th class="server-col" style="padding: 8px 10px;">Servidor</th>
                  {allMeses.map((p) => (
                    <th style="text-align:center; padding: 8px 10px; font-size: 11px;">
                      {p.split("/")[0].slice(0, 3)}<br />
                      <span style="color: var(--text); font-size: 10px;">{p.split("/")[1]}</span>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {heatmap.map(({ servidor, byPeriod }) => (
                  <tr>
                    <td class="server-name-cell">
                      <a href={`/servidor/${servidor.slug}`}>{servidor.nome.split(" ").slice(0, 2).join(" ")}</a>
                    </td>
                    {allMeses.map((p) => {
                      const m = byPeriod.get(p);
                      if (!m || m.status === "empty") return <td class="hm-empty" title={p}>—</td>;
                      const bal = m.balanceMin;
                      const cls = saldoClass(bal);
                      const label = bal !== null ? (bal >= 0 ? "+" : "") + formatMin(bal) : "—";
                      return (
                        <td class={cls} title={`${servidor.nome} · ${p}`}>
                          <a href={`/servidor/${servidor.slug}/${m.periodoSlug}`} style="color: inherit; text-decoration: none;">
                            {label}
                          </a>
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ── Comparativo de % carga ── */}
      <div class="section">
        <div class="section-title">% de carga horária cumprida (todos os meses)</div>
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <table class="rank-table">
            <thead>
              <tr>
                <th>Servidor</th>
                {allMeses.map((p) => (
                  <th style="text-align:center; font-size: 11px; white-space: nowrap;">{p.split("/")[0].slice(0,3)}/{p.split("/")[1]?.slice(2)}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {heatmap.map(({ servidor, byPeriod }) => (
                <tr>
                  <td><a href={`/servidor/${servidor.slug}`}>{servidor.nome.split(" ").slice(0, 2).join(" ")}</a></td>
                  {allMeses.map((p) => {
                    const m = byPeriod.get(p);
                    if (!m || m.status === "empty") return <td style="text-align:center; color: var(--muted)">—</td>;
                    const pct = pctCarga(m.somaCreditoMin, m.cargaEsperadaMin);
                    if (pct === null) return <td style="text-align:center; color: var(--muted)">—</td>;
                    return (
                      <td style="text-align:center;">
                        <div class="progress-bar-wrap" style="min-width: 80px;">
                          <div class="progress-bar-track">
                            <div
                              class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                              style={`width: ${pct}%`}
                            ></div>
                          </div>
                          <span class="progress-pct">{pct}%</span>
                        </div>
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* ── Indicador 1: Taxa de Presença por Batida Real ── */}
      <div class="section">
        <div class="section-title">Taxa de Presença por Batida Real (último mês completo)</div>
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
          <table class="rank-table">
            <thead>
              <tr>
                <th>Servidor</th>
                <th>Período</th>
                <th style="text-align:right">Dias c/ Batida</th>
                <th style="text-align:right">Dias Esperados</th>
                <th>Taxa</th>
              </tr>
            </thead>
            <tbody>
              {presencaReal.map(({ servidor, pct, diasMarcacoes, diasEsperados, periodo }) => (
                <tr>
                  <td><a href={`/servidor/${servidor.slug}`}>{servidor.nome}</a></td>
                  <td style="color: var(--muted); font-size: 12px;">{periodo ?? "—"}</td>
                  <td class="mono" style="text-align:right">{diasMarcacoes}</td>
                  <td class="mono" style="text-align:right">{diasEsperados}</td>
                  <td>
                    {pct !== null ? (
                      <div class="progress-bar-wrap">
                        <div class="progress-bar-track">
                          <div
                            class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                            style={`width: ${Math.min(pct, 100)}%`}
                          ></div>
                        </div>
                        <span class="progress-pct">{pct}%</span>
                      </div>
                    ) : <span style="color: var(--muted)">—</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* ── Indicador 2: Dias por Tipo de Ocorrência ── */}
      {ocorrBreakdown.length > 0 && (
        <div class="section">
          <div class="section-title">Dias por Tipo de Ocorrência (todos os meses)</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="rank-table">
              <thead>
                <tr>
                  <th>Servidor</th>
                  <th>Total</th>
                  <th>Distribuição</th>
                  <th style="text-align:right; color:#3b82f6">PIT</th>
                  <th style="text-align:right; color:#16a34a">Abono</th>
                  <th style="text-align:right; color:#b45309">Afas.</th>
                  <th style="text-align:right; color:#7c3aed">Recesso</th>
                  <th style="text-align:right; color:#64748b">Sist.</th>
                </tr>
              </thead>
              <tbody>
                {ocorrBreakdown.map(({ servidor, totals, total }) => (
                  <tr>
                    <td><a href={`/servidor/${servidor.slug}`}>{servidor.nome}</a></td>
                    <td class="mono" style="text-align:right; font-weight:600">{total}</td>
                    <td style="min-width:160px">
                      <div class="occ-bar">
                        {totals.pit > 0 && <div class="occ-seg occ-seg-pit" style={`flex: ${totals.pit}`} title={`PIT: ${totals.pit}`}></div>}
                        {totals.abono > 0 && <div class="occ-seg occ-seg-abono" style={`flex: ${totals.abono}`} title={`Abono: ${totals.abono}`}></div>}
                        {totals.afastamento > 0 && <div class="occ-seg occ-seg-afas" style={`flex: ${totals.afastamento}`} title={`Afastamento: ${totals.afastamento}`}></div>}
                        {totals.recesso > 0 && <div class="occ-seg occ-seg-recesso" style={`flex: ${totals.recesso}`} title={`Recesso: ${totals.recesso}`}></div>}
                        {totals.sistema > 0 && <div class="occ-seg occ-seg-sistema" style={`flex: ${totals.sistema}`} title={`Sistema: ${totals.sistema}`}></div>}
                      </div>
                    </td>
                    <td class="mono" style="text-align:right">{totals.pit || "—"}</td>
                    <td class="mono" style="text-align:right">{totals.abono || "—"}</td>
                    <td class="mono" style="text-align:right">{totals.afastamento || "—"}</td>
                    <td class="mono" style="text-align:right">{totals.recesso || "—"}</td>
                    <td class="mono" style="text-align:right">{totals.sistema || "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ── Indicador 3: Concentração de Abonos ── */}
      {rankingAbono.length > 0 && (
        <div class="section">
          <div class="section-title">Concentração de Abonos (todos os meses)</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="rank-table">
              <thead>
                <tr>
                  <th style="width:40px">#</th>
                  <th>Servidor</th>
                  <th style="text-align:right">Total Dias Abono</th>
                  <th>Proporção</th>
                </tr>
              </thead>
              <tbody>
                {(() => {
                  const maxAbono = rankingAbono[0]?.totals.abono ?? 1;
                  return rankingAbono.map(({ servidor, totals }, i) => (
                    <tr>
                      <td><span class={`rank-badge ${rankBadgeClass(i)}`}>{i + 1}</span></td>
                      <td><a href={`/servidor/${servidor.slug}`}>{servidor.nome}</a></td>
                      <td class="mono" style="text-align:right; font-weight:600">{totals.abono}</td>
                      <td>
                        <div class="progress-bar-wrap">
                          <div class="progress-bar-track">
                            <div class="progress-bar-fill occ-fill-abono" style={`width: ${Math.round((totals.abono / maxAbono) * 100)}%`}></div>
                          </div>
                          <span class="progress-pct">{Math.round((totals.abono / maxAbono) * 100)}%</span>
                        </div>
                      </td>
                    </tr>
                  ));
                })()}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ── Indicador 4: Dias por Indisponibilidade do Sistema ── */}
      {rankingSistema.length > 0 && (
        <div class="section">
          <div class="section-title">Dias com Indisponibilidade do Sistema (todos os meses)</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="rank-table">
              <thead>
                <tr>
                  <th>Servidor</th>
                  <th style="text-align:right">Dias Perdidos</th>
                  <th>Link</th>
                </tr>
              </thead>
              <tbody>
                {rankingSistema.map(({ servidor, totals }) => (
                  <tr>
                    <td>{servidor.nome}</td>
                    <td class="mono" style="text-align:right; font-weight:600; color: var(--muted)">{totals.sistema}</td>
                    <td><a href={`/servidor/${servidor.slug}`} style="font-size:12px">Ver espelho</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ── Indicador 5: Carga PIT vs. Real (docentes) ── */}
      {pitVsReal.length > 0 && (
        <div class="section">
          <div class="section-title">Carga PIT vs. Real — Docentes (último mês com PIT)</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="rank-table">
              <thead>
                <tr>
                  <th>Servidor</th>
                  <th>Período</th>
                  <th style="text-align:right">Dias PIT</th>
                  <th style="text-align:right">Dias c/ Batida</th>
                  <th>% Justificado via PIT</th>
                </tr>
              </thead>
              <tbody>
                {pitVsReal.map(({ servidor, pitPct, diasPit, diasMarcacoes, periodo }) => (
                  <tr>
                    <td><a href={`/servidor/${servidor.slug}`}>{servidor.nome}</a></td>
                    <td style="color: var(--muted); font-size: 12px;">{periodo ?? "—"}</td>
                    <td class="mono" style="text-align:right">{diasPit}</td>
                    <td class="mono" style="text-align:right">{diasMarcacoes}</td>
                    <td>
                      {pitPct !== null ? (
                        <div class="progress-bar-wrap">
                          <div class="progress-bar-track">
                            <div class="progress-bar-fill occ-fill-pit" style={`width: ${Math.min(pitPct, 100)}%`}></div>
                          </div>
                          <span class="progress-pct">{pitPct}%</span>
                        </div>
                      ) : <span style="color: var(--muted)">—</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* ── Indicador 6: Afastamentos ── */}
      {apenasAfastamentos.length > 0 && (
        <div class="section">
          <div class="section-title">Afastamentos Registrados</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="rank-table">
              <thead>
                <tr>
                  <th>Servidor</th>
                  <th>Tipo</th>
                  <th>Início</th>
                  <th>Fim</th>
                  <th style="text-align:right">Dias</th>
                  <th>Link</th>
                </tr>
              </thead>
              <tbody>
                {apenasAfastamentos.map((af) => (
                  <tr>
                    <td>{af.serverNome}</td>
                    <td style="font-size: 12px; max-width: 260px; white-space: normal;">{af.texto}</td>
                    <td class="mono" style="font-size:12px">{formatDate(af.dataInicio)}</td>
                    <td class="mono" style="font-size:12px">{formatDate(af.dataFim)}</td>
                    <td class="mono" style="text-align:right">{af.dias}</td>
                    <td><a href={`/servidor/${af.serverSlug}`} style="font-size:12px">Ver espelho</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </div>

    <script>
      (function () {
        const raw = sessionStorage.getItem("dashboard_auth");
        if (!raw) {
          sessionStorage.setItem(
            "dashboard_auth",
            JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
          );
          window.location.href = "/login";
          return;
        }
        try {
          if (!JSON.parse(raw).authenticated) {
            sessionStorage.setItem(
              "dashboard_auth",
              JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
            );
            window.location.href = "/login";
          }
        } catch {
          window.location.href = "/login";
        }
        document.querySelectorAll("[data-action='logout']").forEach((btn) => {
          btn.addEventListener("click", () => {
            sessionStorage.removeItem("dashboard_auth");
            window.location.href = "/login";
          });
        });
      })();
    </script>
  </body>
</html>

