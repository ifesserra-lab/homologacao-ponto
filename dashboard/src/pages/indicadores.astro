  }

  .kpi-blue  { border-color: color-mix(in srgb, #3b82f6 40%, transparent); }
  .kpi-blue  .kpi-val { color: #3b82f6; }

  .kpi-green { border-color: color-mix(in srgb, #22c55e 40%, transparent); }
  .kpi-green .kpi-val { color: #16a34a; }

  .kpi-amber { border-color: color-mix(in srgb, #f59e0b 40%, transparent); }
  .kpi-amber .kpi-val { color: #b45309; }

  .kpi-red   { border-color: color-mix(in srgb, #ef4444 40%, transparent); }
  .kpi-red   .kpi-val { color: #dc2626; }

  /* ── Stacked occurrence bar ──────────────────────────────────────── */
  .occ-bar {
    display: flex;
    height: 10px;
    border-radius: 3px;
    overflow: hidden;
    gap: 1px;
    min-width: 120px;
  }

  .occ-seg {
    min-width: 3px;
    height: 100%;
    border-radius: 2px;
  }

  .occ-seg-pit     { background: #3b82f6; }
  .occ-seg-abono   { background: #22c55e; }
  .occ-seg-afas    { background: #f59e0b; }
  .occ-seg-recesso { background: #a78bfa; }
  .occ-seg-sistema { background: #94a3b8; }

  /* progress bar fill variants for occ colors */
  .occ-fill-abono { background: #22c55e !important; }
  .occ-fill-pit   { background: #3b82f6 !important; }
</style>
