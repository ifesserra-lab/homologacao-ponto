---
import { listServers } from "../lib/espelhoRepository";
import ServerCard from "../components/ServerCard.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

const dataDir = import.meta.env.DATA_DIR as string | undefined;
const servidores = listServers(dataDir);
const isEmpty = servidores.length === 0;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Espelhos de Ponto</title>
    <script is:inline>
      const theme = localStorage.getItem("dashboard_theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = theme === "dark" || theme === "light" ? theme : prefersDark ? "dark" : "light";
    </script>
    <link rel="stylesheet" href="/styles/global.css" />
    <script src="/scripts/theme.js" defer></script>
  </head>
  <body>
    <div class="page">
      <header class="page-header">
        <div class="page-header-row">
          <div>
            <h1 class="page-title">Espelhos de Ponto</h1>
            <p class="page-meta">SIGRH · {servidores.length} {servidores.length === 1 ? "servidor" : "servidores"}</p>
          </div>
          <div class="nav-actions">
            <ThemeToggle />
            <button class="logout-btn" data-action="logout" type="button">Sair</button>
          </div>
        </div>
      </header>

      {!isEmpty && (
        <div class="tab-nav">
          <span class="tab-btn active">Servidores</span>
          <a class="tab-btn" href="/indicadores">Indicadores</a>
        </div>
      )}

      {isEmpty ? (
        <div class="empty-state">
          <div class="empty-icon">📂</div>
          <p class="empty-title">Nenhum espelho encontrado</p>
          <p>Execute o batch para exportar espelhos.</p>
          <code class="empty-hint">data/runs/servidores/</code>
        </div>
      ) : (
        <>
          <div class="filter-wrap">
            <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input id="filter-input" type="search" placeholder="Buscar servidor…" aria-label="Filtrar servidores" />
          </div>
          <div class="server-list">
            {servidores.map((s) => <ServerCard servidor={s} />)}
          </div>
        </>
      )}
    </div>

    <style>
      .server-list { display: flex; flex-direction: column; gap: 6px; }
    </style>

    {!isEmpty && (
      <script>
        const input = document.getElementById("filter-input") as HTMLInputElement;
        const items = document.querySelectorAll<HTMLElement>(".card-wrap");
        input?.addEventListener("input", () => {
          const q = input.value.toLowerCase();
          items.forEach((item) => {
            const name = (item.querySelector(".server-name")?.textContent ?? "").toLowerCase();
            item.style.display = name.includes(q) ? "" : "none";
          });
        });
      </script>
    )}
    <script>
      (function () {
        const raw = sessionStorage.getItem("dashboard_auth");
        if (!raw) {
          sessionStorage.setItem(
            "dashboard_auth",
            JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
          );
          window.location.href = "/login";
          return;
        }
        try {
          if (!JSON.parse(raw).authenticated) {
            sessionStorage.setItem(
              "dashboard_auth",
              JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
            );
            window.location.href = "/login";
          }
        } catch {
          window.location.href = "/login";
        }
        document.querySelectorAll("[data-action='logout']").forEach((btn) => {
          btn.addEventListener("click", () => {
            sessionStorage.removeItem("dashboard_auth");
            window.location.href = "/login";
          });
        });
      })();
    </script>
  </body>
</html>
