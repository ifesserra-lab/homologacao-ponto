---
import { listServers, serverDetail, loadAllAfastamentos } from "../../lib/espelhoRepository";
import MonthTable from "../../components/MonthTable.astro";
import { formatMin, pctCarga } from "../../lib/aggregation";
import ThemeToggle from "../../components/ThemeToggle.astro";

export async function getStaticPaths() {
  const dataDir = import.meta.env.DATA_DIR as string | undefined;
  const servidores = listServers(dataDir);
  return servidores.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const dataDir = import.meta.env.DATA_DIR as string | undefined;
const servidor = serverDetail(slug!, dataDir);

if (!servidor) {
  return Astro.redirect("/", 302);
}

const completedCount = servidor.meses.filter(m => m.status === "completed").length;
const emptyCount = servidor.meses.filter(m => m.status === "empty").length;
const completedMeses = servidor.meses.filter(m => m.status === "completed");

// Latest month summary
const latest = completedMeses[completedMeses.length - 1] ?? null;
const latestBalance = latest?.balanceMin ?? null;
const totalHhAllMonths = completedMeses.reduce((s, m) => s + m.somaCreditoMin, 0);
const totalCargaAllMonths = completedMeses.reduce((s, m) => s + m.cargaEsperadaMin, 0);
const overallPct = totalCargaAllMonths > 0 ? Math.min(100, Math.round((totalHhAllMonths / totalCargaAllMonths) * 100)) : null;

// ── Indicadores ──────────────────────────────────────────────────
const ocorrByMonth = completedMeses.map((m) => {
  const o = m.ocorrenciaDias ?? { pit: 0, abono: 0, afastamento: 0, recesso: 0, sistema: 0 };
  const total = o.pit + o.abono + o.afastamento + o.recesso + o.sistema;
  return { mes: m, ocorr: o, total };
});
const hasOcorr = ocorrByMonth.some(x => x.total > 0);

const totalOcorr = {
  pit: completedMeses.reduce((s, m) => s + (m.ocorrenciaDias?.pit ?? 0), 0),
  abono: completedMeses.reduce((s, m) => s + (m.ocorrenciaDias?.abono ?? 0), 0),
  afastamento: completedMeses.reduce((s, m) => s + (m.ocorrenciaDias?.afastamento ?? 0), 0),
  recesso: completedMeses.reduce((s, m) => s + (m.ocorrenciaDias?.recesso ?? 0), 0),
  sistema: completedMeses.reduce((s, m) => s + (m.ocorrenciaDias?.sistema ?? 0), 0),
};
const totalOcorrSum = totalOcorr.pit + totalOcorr.abono + totalOcorr.afastamento + totalOcorr.recesso + totalOcorr.sistema;

const presencaByMonth = completedMeses.map((m) => {
  const diasEsperados = m.cargaEsperadaMin > 0 ? Math.round(m.cargaEsperadaMin / 480) : 0;
  const pct = diasEsperados > 0 ? Math.round((m.daysWithMarcacoes / diasEsperados) * 100) : null;
  return { mes: m, diasEsperados, pct };
});

const allAfastamentos = loadAllAfastamentos(dataDir);
const meuAfastamentos = allAfastamentos.filter(a => a.serverSlug === slug && a.categoria === "afastamento");

const pitByMonth = completedMeses
  .filter(m => m.ocorrenciaDias && m.ocorrenciaDias.pit > 0)
  .map(m => ({ mes: m, diasPit: m.ocorrenciaDias!.pit, pitPct: m.pitJustificadoPct }));

function formatDate(iso: string): string {
  if (!iso) return "—";
  const parts = iso.split("-");
  if (parts.length !== 3) return iso;
  return `${parts[2]}/${parts[1]}/${parts[0]}`;
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{servidor.nome} — Espelhos de Ponto</title>
    <script is:inline>
      const theme = localStorage.getItem("dashboard_theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = theme === "dark" || theme === "light" ? theme : prefersDark ? "dark" : "light";
    </script>
    <link rel="stylesheet" href="/styles/global.css" />
    <script src="/scripts/theme.js" defer></script>
  </head>
  <body>
    <div class="page">
      <div class="nav-row">
        <a class="back" href="/">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Servidores
        </a>
        <div class="nav-actions">
          <ThemeToggle />
          <button class="logout-btn" data-action="logout" type="button">Sair</button>
        </div>
      </div>

      <header class="page-header">
        <h1 class="page-title">{servidor.nome}</h1>
        <p class="page-meta">
          {servidor.siape && <>SIAPE {servidor.siape} · </>}
          {servidor.periodoRange}
        </p>
      </header>

      <div class="stats">
        <div class="stat">
          <div class="stat-label">Total</div>
          <div class="stat-value">{servidor.totalMeses}</div>
        </div>
        <div class="stat">
          <div class="stat-label">Completos</div>
          <div class="stat-value">{completedCount}</div>
        </div>
        {emptyCount > 0 && (
          <div class="stat">
            <div class="stat-label">Sem registros</div>
            <div class="stat-value warn">{emptyCount}</div>
          </div>
        )}
        {latestBalance !== null && (
          <div class={`stat ${latestBalance < -480 ? "stat-falta" : latestBalance >= 0 ? "stat-ok" : ""}`}>
            <div class="stat-label">Saldo atual</div>
            <div class={`stat-value mono ${latestBalance < 0 ? "warn" : "ok"}`}>
              {latestBalance >= 0 ? "+" : ""}{formatMin(latestBalance)}
            </div>
          </div>
        )}
        {overallPct !== null && (
          <div class="stat">
            <div class="stat-label">% Carga cumprida</div>
            <div class={`stat-value ${overallPct < 60 ? "warn" : overallPct >= 90 ? "ok" : ""}`}>{overallPct}%</div>
          </div>
        )}
      </div>

      <div class="tab-bar">
        <button class="tab-btn active" data-tab="historico">Histórico</button>
        <button class="tab-btn" data-tab="indicadores">Indicadores</button>
      </div>

      <div id="tab-historico" class="tab-panel">

      {completedMeses.length > 0 && (
        <div class="section">
          <div class="section-title">Série histórica</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm);">
            <table class="history-table">
              <thead>
                <tr>
                  <th>Período</th>
                  <th>Horas Registradas</th>
                  <th>Horas Homologadas</th>
                  <th>Carga Esperada</th>
                  <th>% Carga</th>
                  <th>Saldo do Mês</th>
                  <th>Dias com Marcação</th>
                </tr>
              </thead>
              <tbody>
                {completedMeses.map((m) => {
                  const pct = pctCarga(m.somaCreditoMin, m.cargaEsperadaMin);
                  const bal = m.balanceMin;
                  return (
                    <tr>
                      <td><a href={`/servidor/${slug}/${m.periodoSlug}`}>{m.periodoReferencia}</a></td>
                      <td class="mono">{formatMin(m.somaHrMin)}</td>
                      <td class="mono">{formatMin(m.somaCreditoMin)}</td>
                      <td class="mono">{formatMin(m.cargaEsperadaMin)}</td>
                      <td>
                        {pct !== null ? (
                          <div class="progress-bar-wrap">
                            <div class="progress-bar-track">
                              <div
                                class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                                style={`width: ${pct}%`}
                              ></div>
                            </div>
                            <span class="progress-pct">{pct}%</span>
                          </div>
                        ) : "—"}
                      </td>
                      <td>
                        {bal !== null ? (
                          <span class={`saldo-chip ${bal > 0 ? "pos" : bal === 0 ? "zero" : bal >= -240 ? "neg-mild" : "neg-severe"}`}>
                            {bal >= 0 ? "+" : ""}{formatMin(bal)}
                          </span>
                        ) : "—"}
                      </td>
                      <td>{m.daysWithMarcacoes}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <MonthTable meses={servidor.meses} slug={slug!} />

      </div>{/* end tab-historico */}

      <div id="tab-indicadores" class="tab-panel" style="display:none">

      {/* ── Indicadores do Servidor ── */}
      {completedMeses.length > 0 && (
        <div class="section" style="margin-top: 8px;">
          <div class="section-title" style="display:none">Indicadores</div>

          {/* KPI cards */}
          {(totalOcorrSum > 0 || meuAfastamentos.length > 0) && (
            <div class="stats" style="margin-bottom: 20px;">
              {totalOcorrSum > 0 && (
                <div class="stat">
                  <div class="stat-label">Ocorrências Total</div>
                  <div class="stat-value">{totalOcorrSum}</div>
                </div>
              )}
              {totalOcorr.abono > 0 && (
                <div class="stat stat-abono">
                  <div class="stat-label">Dias Abono</div>
                  <div class="stat-value kpi-green-val">{totalOcorr.abono}</div>
                </div>
              )}
              {totalOcorr.afastamento > 0 && (
                <div class="stat stat-afas">
                  <div class="stat-label">Dias Afastamento</div>
                  <div class="stat-value kpi-amber-val">{totalOcorr.afastamento}</div>
                </div>
              )}
              {totalOcorr.pit > 0 && (
                <div class="stat stat-pit">
                  <div class="stat-label">Dias PIT</div>
                  <div class="stat-value kpi-blue-val">{totalOcorr.pit}</div>
                </div>
              )}
              {totalOcorr.recesso > 0 && (
                <div class="stat stat-recesso">
                  <div class="stat-label">Dias Recesso</div>
                  <div class="stat-value kpi-purple-val">{totalOcorr.recesso}</div>
                </div>
              )}
              {totalOcorr.sistema > 0 && (
                <div class="stat">
                  <div class="stat-label">Indisp. Sistema</div>
                  <div class="stat-value" style="color: var(--muted)">{totalOcorr.sistema}</div>
                </div>
              )}
              {meuAfastamentos.length > 0 && (
                <div class={`stat ${meuAfastamentos.length > 0 ? "stat-falta" : ""}`}>
                  <div class="stat-label">Afastamentos</div>
                  <div class={`stat-value ${meuAfastamentos.length > 0 ? "warn" : ""}`}>{meuAfastamentos.length}</div>
                </div>
              )}
            </div>
          )}

          {/* Taxa de Presença por Mês */}
          <div class="section-sub-title">Taxa de Presença por Batida Real</div>
          <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); margin-bottom: 20px;">
            <table class="history-table">
              <thead>
                <tr>
                  <th>Período</th>
                  <th style="text-align:right">Dias c/ Batida</th>
                  <th style="text-align:right">Dias Esperados</th>
                  <th>Taxa</th>
                </tr>
              </thead>
              <tbody>
                {presencaByMonth.map(({ mes, diasEsperados, pct }) => (
                  <tr>
                    <td><a href={`/servidor/${slug}/${mes.periodoSlug}`}>{mes.periodoReferencia}</a></td>
                    <td class="mono" style="text-align:right">{mes.daysWithMarcacoes}</td>
                    <td class="mono" style="text-align:right">{diasEsperados}</td>
                    <td>
                      {pct !== null ? (
                        <div class="progress-bar-wrap">
                          <div class="progress-bar-track">
                            <div
                              class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                              style={`width: ${Math.min(pct, 100)}%`}
                            ></div>
                          </div>
                          <span class="progress-pct">{pct}%</span>
                        </div>
                      ) : <span style="color: var(--muted)">—</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Ocorrências por Mês */}
          {hasOcorr && (
            <>
              <div class="section-sub-title">Ocorrências por Mês</div>
              <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); margin-bottom: 20px;">
                <table class="history-table">
                  <thead>
                    <tr>
                      <th>Período</th>
                      <th>Total</th>
                      <th>Distribuição</th>
                      <th style="text-align:right; color:#3b82f6">PIT</th>
                      <th style="text-align:right; color:#16a34a">Abono</th>
                      <th style="text-align:right; color:#b45309">Afas.</th>
                      <th style="text-align:right; color:#7c3aed">Recesso</th>
                      <th style="text-align:right; color:#64748b">Sist.</th>
                    </tr>
                  </thead>
                  <tbody>
                    {ocorrByMonth.map(({ mes, ocorr, total }) => (
                      <tr>
                        <td><a href={`/servidor/${slug}/${mes.periodoSlug}`}>{mes.periodoReferencia}</a></td>
                        <td class="mono" style="font-weight:600">{total || "—"}</td>
                        <td style="min-width:120px">
                          {total > 0 ? (
                            <div class="occ-bar">
                              {ocorr.pit > 0 && <div class="occ-seg occ-seg-pit" style={`flex: ${ocorr.pit}`} title={`PIT: ${ocorr.pit}`}></div>}
                              {ocorr.abono > 0 && <div class="occ-seg occ-seg-abono" style={`flex: ${ocorr.abono}`} title={`Abono: ${ocorr.abono}`}></div>}
                              {ocorr.afastamento > 0 && <div class="occ-seg occ-seg-afas" style={`flex: ${ocorr.afastamento}`} title={`Afastamento: ${ocorr.afastamento}`}></div>}
                              {ocorr.recesso > 0 && <div class="occ-seg occ-seg-recesso" style={`flex: ${ocorr.recesso}`} title={`Recesso: ${ocorr.recesso}`}></div>}
                              {ocorr.sistema > 0 && <div class="occ-seg occ-seg-sistema" style={`flex: ${ocorr.sistema}`} title={`Sistema: ${ocorr.sistema}`}></div>}
                            </div>
                          ) : <span style="color: var(--muted)">—</span>}
                        </td>
                        <td class="mono" style="text-align:right">{ocorr.pit || "—"}</td>
                        <td class="mono" style="text-align:right">{ocorr.abono || "—"}</td>
                        <td class="mono" style="text-align:right">{ocorr.afastamento || "—"}</td>
                        <td class="mono" style="text-align:right">{ocorr.recesso || "—"}</td>
                        <td class="mono" style="text-align:right">{ocorr.sistema || "—"}</td>
                      </tr>
                    ))}
                  </tbody>
                  {totalOcorrSum > 0 && (
                    <tfoot>
                      <tr style="font-weight: 600; border-top: 2px solid var(--border);">
                        <td>Total</td>
                        <td class="mono" style="font-weight:700">{totalOcorrSum}</td>
                        <td>
                          <div class="occ-bar">
                            {totalOcorr.pit > 0 && <div class="occ-seg occ-seg-pit" style={`flex: ${totalOcorr.pit}`} title={`PIT: ${totalOcorr.pit}`}></div>}
                            {totalOcorr.abono > 0 && <div class="occ-seg occ-seg-abono" style={`flex: ${totalOcorr.abono}`} title={`Abono: ${totalOcorr.abono}`}></div>}
                            {totalOcorr.afastamento > 0 && <div class="occ-seg occ-seg-afas" style={`flex: ${totalOcorr.afastamento}`} title={`Afastamento: ${totalOcorr.afastamento}`}></div>}
                            {totalOcorr.recesso > 0 && <div class="occ-seg occ-seg-recesso" style={`flex: ${totalOcorr.recesso}`} title={`Recesso: ${totalOcorr.recesso}`}></div>}
                            {totalOcorr.sistema > 0 && <div class="occ-seg occ-seg-sistema" style={`flex: ${totalOcorr.sistema}`} title={`Sistema: ${totalOcorr.sistema}`}></div>}
                          </div>
                        </td>
                        <td class="mono" style="text-align:right">{totalOcorr.pit || "—"}</td>
                        <td class="mono" style="text-align:right">{totalOcorr.abono || "—"}</td>
                        <td class="mono" style="text-align:right">{totalOcorr.afastamento || "—"}</td>
                        <td class="mono" style="text-align:right">{totalOcorr.recesso || "—"}</td>
                        <td class="mono" style="text-align:right">{totalOcorr.sistema || "—"}</td>
                      </tr>
                    </tfoot>
                  )}
                </table>
              </div>
            </>
          )}

          {/* PIT vs Real */}
          {pitByMonth.length > 0 && (
            <>
              <div class="section-sub-title">Carga PIT vs. Real</div>
              <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); margin-bottom: 20px;">
                <table class="history-table">
                  <thead>
                    <tr>
                      <th>Período</th>
                      <th style="text-align:right">Dias PIT</th>
                      <th style="text-align:right">Dias c/ Batida</th>
                      <th>% Justificado via PIT</th>
                    </tr>
                  </thead>
                  <tbody>
                    {pitByMonth.map(({ mes, diasPit, pitPct }) => (
                      <tr>
                        <td><a href={`/servidor/${slug}/${mes.periodoSlug}`}>{mes.periodoReferencia}</a></td>
                        <td class="mono" style="text-align:right">{diasPit}</td>
                        <td class="mono" style="text-align:right">{mes.daysWithMarcacoes}</td>
                        <td>
                          {pitPct !== null ? (
                            <div class="progress-bar-wrap">
                              <div class="progress-bar-track">
                                <div class="progress-bar-fill occ-fill-pit" style={`width: ${Math.min(pitPct, 100)}%`}></div>
                              </div>
                              <span class="progress-pct">{pitPct}%</span>
                            </div>
                          ) : <span style="color: var(--muted)">—</span>}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}

          {/* Afastamentos */}
          {meuAfastamentos.length > 0 && (
            <>
              <div class="section-sub-title">Afastamentos Registrados</div>
              <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); margin-bottom: 20px;">
                <table class="history-table">
                  <thead>
                    <tr>
                      <th>Tipo</th>
                      <th>Início</th>
                      <th>Fim</th>
                      <th style="text-align:right">Dias</th>
                      <th>Período</th>
                    </tr>
                  </thead>
                  <tbody>
                    {meuAfastamentos.map((af) => (
                      <tr>
                        <td style="font-size: 12px; max-width: 280px; white-space: normal;">{af.texto}</td>
                        <td class="mono" style="font-size:12px">{formatDate(af.dataInicio)}</td>
                        <td class="mono" style="font-size:12px">{formatDate(af.dataFim)}</td>
                        <td class="mono" style="text-align:right">{af.dias}</td>
                        <td style="font-size:12px; color: var(--muted)">
                          {af.dataInicio ? af.dataInicio.slice(0, 7) : "—"}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}
        </div>
      )}

      </div>{/* end tab-indicadores */}

    </div>
    <script>
      (function () {
        const raw = sessionStorage.getItem("dashboard_auth");
        if (!raw) {
          sessionStorage.setItem(
            "dashboard_auth",
            JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
          );
          window.location.href = "/login";
          return;
        }
        try {
          if (!JSON.parse(raw).authenticated) {
            sessionStorage.setItem(
              "dashboard_auth",
              JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
            );
            window.location.href = "/login";
          }
        } catch {
          window.location.href = "/login";
        }
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const target = btn.dataset.tab!;
            document.querySelectorAll(".tab-btn").forEach((b) => b.classList.remove("active"));
            document.querySelectorAll<HTMLElement>(".tab-panel").forEach((p) => { p.style.display = "none"; });
            btn.classList.add("active");
            const panel = document.getElementById("tab-" + target);
            if (panel) panel.style.display = "";
          });
        });

        document.querySelectorAll("[data-action='logout']").forEach((btn) => {
          btn.addEventListener("click", () => {
            sessionStorage.removeItem("dashboard_auth");
            window.location.href = "/login";
          });
        });
      })();
    </script>
  </body>
</html>

<style>
  .tab-bar {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }

  .tab-btn {
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 500;
    border: none;
    background: none;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    border-radius: 0;
    transition: color 0.15s, border-color 0.15s;
  }

  .tab-btn:hover { color: var(--text); }

  .tab-btn.active {
    color: var(--text);
    border-bottom-color: var(--blue, #3b82f6);
    font-weight: 600;
  }

  .section-sub-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 16px 0 8px;
  }

  .occ-bar {
    display: flex;
    height: 10px;
    border-radius: 3px;
    overflow: hidden;
    gap: 1px;
    min-width: 100px;
  }

  .occ-seg {
    min-width: 3px;
    height: 100%;
    border-radius: 2px;
  }

  .occ-seg-pit     { background: #3b82f6; }
  .occ-seg-abono   { background: #22c55e; }
  .occ-seg-afas    { background: #f59e0b; }
  .occ-seg-recesso { background: #a78bfa; }
  .occ-seg-sistema { background: #94a3b8; }

  .occ-fill-pit    { background: #3b82f6 !important; }

  .stat-abono   { border-color: color-mix(in srgb, #22c55e 40%, transparent); }
  .stat-afas    { border-color: color-mix(in srgb, #f59e0b 40%, transparent); }
  .stat-pit     { border-color: color-mix(in srgb, #3b82f6 40%, transparent); }
  .stat-recesso { border-color: color-mix(in srgb, #a78bfa 40%, transparent); }

  .kpi-green-val  { color: #16a34a; }
  .kpi-amber-val  { color: #b45309; }
  .kpi-blue-val   { color: #3b82f6; }
  .kpi-purple-val { color: #7c3aed; }
</style>
