---
import { listServers, monthDetail } from "../../../lib/espelhoRepository";
import { aggregateMonth, formatMin, pctCarga, countAbsentWorkdays, countOcorrencias } from "../../../lib/aggregation";
import DayTable from "../../../components/DayTable.astro";

export async function getStaticPaths() {
  const dataDir = import.meta.env.DATA_DIR as string | undefined;
  const servidores = listServers(dataDir);
  const paths: { params: { slug: string; periodo: string } }[] = [];
  for (const s of servidores) {
    for (const mes of s.meses) {
      paths.push({ params: { slug: s.slug, periodo: mes.periodoSlug } });
    }
  }
  return paths;
}

const { slug, periodo } = Astro.params;
const dataDir = import.meta.env.DATA_DIR as string | undefined;
const espelho = monthDetail(slug!, periodo!, dataDir);

if (!espelho) {
  return Astro.redirect(`/servidor/${slug}`, 302);
}

const agg = aggregateMonth(espelho.registros, espelho.resumo ?? null, espelho.captured_at);
const incompleteDays = espelho.registros.filter(r => {
  if (!r.debito) return false;
  const [h, m] = r.debito.split(":").map(Number);
  return (h * 60 + m) > 0;
}).length;

const balanceMin = agg.balanceMin;
const faltaMin = balanceMin !== null && balanceMin < 0 ? -balanceMin : 0;
const saldoPositivoMin = balanceMin !== null && balanceMin > 0 ? balanceMin : 0;

const pct = pctCarga(agg.somaCreditoMin, agg.cargaEsperadaMin);
const absentDays = countAbsentWorkdays(espelho.registros);
const ocorrencias = countOcorrencias(espelho.registros);

// Débito não compensável from resumo
const dncText = espelho.resumo?.totalizacao_debito_nao_compensavel ?? null;
const debitoNaoCompMin = dncText
  ? (() => {
      const neg = dncText.startsWith("-");
      const abs = neg ? dncText.slice(1) : dncText;
      const [h, m] = abs.split(":").map(Number);
      const v = h * 60 + m;
      return neg ? -v : v;
    })()
  : null;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{espelho.periodo_referencia} · {espelho.servidor.nome}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="page-wide">
      <div class="nav-row">
        <a class="back" href={`/servidor/${slug}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          {espelho.servidor.nome}
        </a>
        <button class="logout-btn" data-action="logout" type="button">Sair</button>
      </div>

      <header class="page-header">
        <h1 class="page-title">{espelho.periodo_referencia}</h1>
        <p class="page-meta">
          {espelho.servidor.nome}
          {espelho.servidor.identificador && <> · SIAPE {espelho.servidor.identificador}</>}
        </p>
      </header>

      {espelho.status === "empty" ? (
        <div class="notice">Este mês não possui registros de ponto.</div>
      ) : (
        <>
          <div class="stats">
            <div class="stat">
              <div class="stat-label">Carga Esperada</div>
              <div class="stat-value mono">{formatMin(agg.cargaEsperadaMin)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Horas Registradas</div>
              <div class="stat-value mono">{formatMin(agg.somaHrMin)}</div>
            </div>
            <div class="stat">
              <div class="stat-label">Horas Homologadas</div>
              <div class="stat-value mono">{formatMin(agg.somaCreditoMin)}</div>
            </div>
            {pct !== null && (
              <div class="stat">
                <div class="stat-label">% Carga cumprida</div>
                <div class="stat-value">
                  <div class="progress-bar-wrap">
                    <div class="progress-bar-track">
                      <div
                        class={`progress-bar-fill ${pct < 60 ? "bad" : pct < 85 ? "warn" : ""}`}
                        style={`width: ${pct}%`}
                      ></div>
                    </div>
                    <span class="progress-pct">{pct}%</span>
                  </div>
                </div>
              </div>
            )}
            <div class="stat">
              <div class="stat-label">Dias com marcação</div>
              <div class="stat-value">{agg.daysWithMarcacoes}</div>
            </div>
            {incompleteDays > 0 && (
              <div class="stat">
                <div class="stat-label">Jornada incompleta</div>
                <div class="stat-value warn">{incompleteDays}</div>
              </div>
            )}
            {absentDays > 0 && (
              <div class="stat">
                <div class="stat-label">Dias sem marcação (úteis)</div>
                <div class="stat-value warn">{absentDays}</div>
              </div>
            )}
            {debitoNaoCompMin !== null && debitoNaoCompMin !== 0 && (
              <div class="stat stat-falta">
                <div class="stat-label">Débito não compensável</div>
                <div class="stat-value warn mono">{formatMin(Math.abs(debitoNaoCompMin))}</div>
              </div>
            )}
            {faltaMin > 0 ? (
              <div class="stat stat-falta">
                <div class="stat-label">Falta compensar</div>
                <div class="stat-value warn mono">{formatMin(faltaMin)}</div>
              </div>
            ) : (
              <div class="stat stat-ok">
                <div class="stat-label">Saldo do mês</div>
                <div class="stat-value ok mono">+{formatMin(saldoPositivoMin)}</div>
              </div>
            )}
          </div>

          {ocorrencias.length > 0 && (
            <div class="section" style="margin-bottom: 1.25rem;">
              <div class="section-title">Ocorrências no mês</div>
              <div class="ocorr-list">
                {ocorrencias.map((o) => (
                  <div class="ocorr-row">
                    <span class="ocorr-name">{o.type}</span>
                    <span class="ocorr-count">{o.count}×</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {incompleteDays > 0 && (
            <div class="legend">
              <span class="legend-dot"></span>
              Dias com jornada incompleta (débito &gt; 0)
            </div>
          )}

          {espelho.resumo && (
            <details class="resumo-sigrh">
              <summary class="resumo-sigrh-title">Resumo das Horas Apuradas no Mês <span class="resumo-badge">SIGRH</span></summary>
              <div class="resumo-grid">
                <div class="resumo-group">
                  <div class="resumo-group-title">Carga e Registros</div>
                  <div class="resumo-row"><span>Carga Contratada</span><span class="mono">{espelho.resumo.carga_horaria_contratada ?? "—"}</span></div>
                  <div class="resumo-row"><span>Carga Esperada no Mês</span><span class="mono">{espelho.resumo.carga_horaria_esperada_mes ?? "—"}</span></div>
                  <div class="resumo-row"><span>Horas Registradas</span><span class="mono">{espelho.resumo.total_horas_registradas ?? "—"}</span></div>
                  <div class="resumo-row"><span>Horas Justificadas</span><span class="mono">{espelho.resumo.total_horas_justificadas ?? "—"}</span></div>
                  <div class="resumo-row resumo-row-highlight"><span>Horas Homologadas</span><span class="mono">{espelho.resumo.total_horas_homologadas ?? "—"}</span></div>
                </div>
                <div class="resumo-group">
                  <div class="resumo-group-title">Compensação Anterior</div>
                  <div class="resumo-row"><span>Saldo Mês Anterior</span><span class="mono">{espelho.resumo.saldo_mes_anterior_compensacao ?? "—"}</span></div>
                  <div class="resumo-row"><span>Horas Anteriores Compensadas</span><span class="mono">{espelho.resumo.total_horas_mes_anterior_compensadas ?? "—"}</span></div>
                  <div class="resumo-row"><span>Débito Anterior Não Compensado</span><span class="mono">{espelho.resumo.debito_mes_anterior_nao_compensado ?? "—"}</span></div>
                </div>
                <div class="resumo-group">
                  <div class="resumo-group-title">Débitos</div>
                  <div class="resumo-row"><span>Débito Atual Não Autorizado</span><span class="mono resumo-neg">{espelho.resumo.debito_mes_atual_nao_autorizado ?? "—"}</span></div>
                  <div class="resumo-row"><span>Outros Débitos Vencidos</span><span class="mono">{espelho.resumo.outros_debitos_nao_compensados_vencidos ?? "—"}</span></div>
                  <div class="resumo-row"><span>Total Débito Não Compensável</span><span class="mono resumo-neg">{espelho.resumo.totalizacao_debito_nao_compensavel ?? "—"}</span></div>
                </div>
                <div class="resumo-group">
                  <div class="resumo-group-title">Saldo Final</div>
                  <div class="resumo-row"><span>Horas Pendentes Compensação</span><span class="mono resumo-neg">{espelho.resumo.total_horas_pendentes_compensacao ?? "—"}</span></div>
                  <div class="resumo-row resumo-row-highlight"><span>Saldo do Mês</span><span class="mono resumo-neg">{espelho.resumo.saldo_horas_mes ?? "—"}</span></div>
                  <div class="resumo-row"><span>Saldo a Compensar no Próximo Mês</span><span class="mono resumo-neg">{espelho.resumo.saldo_horas_mes_compensar_proximo ?? "—"}</span></div>
                  <div class="resumo-row"><span>Crédito Disponível</span><span class="mono">{espelho.resumo.credito_horas_disponivel_mes ?? "—"}</span></div>
                  <div class="resumo-row"><span>Crédito em Horas</span><span class="mono">{espelho.resumo.credito_em_horas ?? "—"}</span></div>
                </div>
              </div>
            </details>
          )}

          <DayTable registros={espelho.registros} />
        </>
      )}
    </div>
    <script>
      (function () {
        const raw = sessionStorage.getItem("dashboard_auth");
        if (!raw) {
          sessionStorage.setItem(
            "dashboard_auth",
            JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
          );
          window.location.href = "/login";
          return;
        }
        try {
          if (!JSON.parse(raw).authenticated) {
            sessionStorage.setItem(
              "dashboard_auth",
              JSON.stringify({ authenticated: false, redirect: window.location.pathname }),
            );
            window.location.href = "/login";
          }
        } catch {
          window.location.href = "/login";
        }
        document.querySelectorAll("[data-action='logout']").forEach((btn) => {
          btn.addEventListener("click", () => {
            sessionStorage.removeItem("dashboard_auth");
            window.location.href = "/login";
          });
        });
      })();
    </script>
  </body>
</html>
